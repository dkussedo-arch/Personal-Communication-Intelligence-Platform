# Required for AI features and Promptfoo evals
ANTHROPIC_API_KEY=

# Helicone LLM observability (optional — requests bypass Helicone if unset)
HELICONE_API_KEY=

# Required when Supabase-backed features are enabled
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog analytics (optional — events are skipped if unset)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
